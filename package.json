{
  "name": "obsidian-milestone",
  "version": "1.0.0",
  "description": "A full-featured Kanban board with team members, milestones with ordering, and filtering by assignee, milestone, priority and tags.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint . --ext .ts",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "kanban",
    "milestone",
    "project-management"
  ],
  "author": "Achraf Ayar",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.20.1",
    "eslint": "^9.30.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^17.3.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  }
}
